# Supabase - required (see docs/supabase-migration.md)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Admin routes - required
ADMIN_SECRET=
# Also set as a GitHub Actions repository secret (Settings -> Secrets and
# variables -> Actions) - .github/workflows/ingest-cron.yml uses it to call
# /api/cron/ingest on a schedule, since Vercel Cron's Hobby plan only allows
# daily invocations.
CRON_SECRET=

# Server-side ingest job's live-data provider
NEXT_PUBLIC_USE_MOCK_DATA=false
API_FOOTBALL_KEY=
NEXT_PUBLIC_LIVE_POLL_INTERVAL_MS=60000
